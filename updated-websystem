def accs_functions():

    # ==============================
    # ACCOUNTS (LIST OF TUPLES)
    # ==============================
    accounts = [
        ("mel", "1234"),
        ("nelgiesdyn", "pass"),
        ("glaipam", "qwerty"),
        ("dixnykei", "1111"),
        ("SamAxisinism", "abcd")
    ]

    # ==============================
    # LOGIN FUNCTION
    # ==============================
    def login():
        while True:
            username = input("Enter username: ")
            password = input("Enter password: ")

            for acc in accounts:
                if username == acc[0] and password == acc[1]:
                    print("\nWelcome,", username)
                    print("Professor: Sir Mel\n")
                    return
            print("Invalid! Try again.\n")


    # ==============================
    # MINI PROGRAMS
    # ==============================
    def program1():
        # EVEN OR ODD
        num = int(input("Enter a number: "))
        if num % 2 == 0:
            print("Even number\n")
        else:
            print("Odd number\n")


    def program2():
        # SUM OF NUMBERS USING LOOP
        total = 0
        n = int(input("Enter how many numbers: "))
        for i in range(n):
            num = int(input("Enter number: "))
            total += num
        print("Total:", total, "\n")


    def program3():
        # LIST EXAMPLE
        items = []
        n = int(input("How many items: "))
        for i in range(n):
            item = input("Enter item: ")
            items.append(item)
        print("List:", items, "\n")


    def program4():
        # TUPLE EXAMPLE
        tup = ("Apple", "Banana", "Cherry")
        print("Tuple:", tup)
        print("First item:", tup[0], "\n")


    def program5():
        # SIMPLE CALCULATOR
        a = int(input("Enter first number: "))
        b = int(input("Enter second number: "))
        op = input("Operator (+, -, *, /): ")

        if op == "+":
            print("Result:", a + b)
        elif op == "-":
            print("Result:", a - b)
        elif op == "*":
            print("Result:", a * b)
        elif op == "/":
            if b != 0:
                print("Result:", a / b)
            else:
                print("Cannot divide by zero")
        else:
            print("Invalid operator")
        print()


    # ==============================
    # MENU FUNCTION
    # ==============================
    def menu():
        while True:
            print("==== MAIN MENU ====")
            print("1. Even or Odd")
            print("2. Sum of Numbers")
            print("3. List Example")
            print("4. Tuple Example")
            print("5. Calculator")
            print("6. Exit")

            choice = input("Choose (1-6): ")

            if choice == "1":
                program1()
            elif choice == "2":
                program2()
            elif choice == "3":
                program3()
            elif choice == "4":
                program4()
            elif choice == "5":
                program5()
            elif choice == "6":
                print("Exiting program...")
                break
            else:
                print("Invalid choice\n")


    # ==============================
    # MAIN FUNCTION
    # ==============================
    def main():
        login()
        menu()


    # RUN PROGRAM
    main()




