#****************2. GUESING GAME == PAMILGAN****************

    def guessing_game():
        print("\n🎮 === GUESSING GAME (LOOPS FOCUS) === 🎮")

        score = 0

        for round_num in range(1, 4):
            print("\n" + "="*30)
            print("🔥 Round", round_num)
            print("="*30)

            secret = random.randint(1, 20)
            lives = 5

            while lives > 0:
                print("\n❤️ Lives:", lives)
                guess = int(input("👉 Guess the number (1-20): "))

                if guess == secret:
                    print("🎉 Correct! You win this round!")
                    score += 1
                    break
                elif guess < secret:
                    print("📉 Too low!")
                else:
                    print("📈 Too high!")

                lives -= 1

            if lives == 0:
                print("💀 You lost! The number was:", secret)

        print("\n🏁 Game Over!")
        print("⭐ Your Score:", score, "/ 3")


